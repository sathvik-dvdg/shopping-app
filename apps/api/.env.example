# Server Configuration
PORT=5000
NODE_ENV=development
CORS_ORIGIN=*

# Database Configuration
# In Docker Compose, 'localhost' is replaced with the service name 'mongo'
MONGO_URI=mongodb://localhost:27017/shopping-cart

# JWT Secrets (Generate strong random strings for production)
JWT_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here